<!DOCTYPE html>
<html lang="en">
	<head>
		<title>{{ title }} - Headless Wordpress</title>
		<meta charset="utf-8">
		<meta http-equiv="x-ua-compatible" content="ie=edge">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<meta name="description" content="{{ meta.description }}">
		<meta name="robots" content="follow, index, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
		<link rel="canonical" href="{{ meta.page_url }}">
		<meta property="og:locale" content="en_US" />
		<meta property="og:type" content="article" />
		<meta property="og:title" content="{{ title }}" />
		<meta property="og:description" content="{{ meta.description }}" />
		<meta property="og:url" content="{{ meta.page_url }}" />
		<meta property="og:site_name" content="Headless Wordpress" />
		<script type="application/ld+json">{{{ generate-schema meta }}}</script>
		<link rel="icon" type="image/x-icon" href="/img/favicon.ico">
		<link rel="stylesheet" media="print" href="/css/print.css" />
		<link rel="stylesheet" href="/css/style.css" />
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-EHVZLWL48R"></script>
		<script>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-EHVZLWL48R');
		</script>
	</head>
	<body>
		<header class="header">
			<nav aria-label="Main Navigation" class="header-nav">
				<a href="/" class="home"><span class="screen-reader-text">Home</span></a>
				<ul class="header-links">
					<li><a href="/timeline/"{{if-active post_type 'timeline' }}>Timeline</a></li>
					<li><a href="/people/"{{if-active post_type 'people' }}>People</a></li>
					<li><a href="/noun/"{{if-active post_type 'noun' }}>Places & Events</a></li>
					<li><a href="/glossary/"{{if-active post_type 'glossary' }}>Glossary</a></li>
					<li><a href="/media/"{{if-active post_type 'media' }}>Media</a></li>
					<li><a href="/archives/"{{if-active post_type 'archives' }}>Archives</a></li>
				</ul>
				<button class="mobile-menu-toggle">
					<span class="screen-reader-text">Mobile Menu Toggle</span>
					<span></span>
					<span></span>
					<span></span>
				</button>
			</nav>
		</header>

		<main class="main">
			{{{ body }}}
		</main>

		<footer class="footer">
			<nav aria-label="Footer Navigation">
				<ul class="footer-nav">
					<li><a href="/what-is"{{if-active slug 'what-is' }}>What is This Site?</a></li>
					<li><a href="/sources"{{if-active slug 'sources' }}>Sources</a></li>
					<li><a href="/about"{{if-active slug 'about' }}>About this Site</a></li>
					<li><a href="/hangul"{{if-active slug 'hangul' }}>한국어 출처</a></li>
					<li><a href="/index">Index</a></li>
				</ul>
			</nav>
		</footer>

		<script src="/js/scripts.min.js"></script>
	</body>
</html>
